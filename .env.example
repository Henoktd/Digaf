# Root-level .env consumed by docker-compose.yml for variable substitution
# (Compose reads this automatically since it sits next to docker-compose.yml).
# Copy to ".env" on the server and fill in real values — never commit the real ".env".

# Postgres container — pick a strong password, this becomes the digaf_app DB password
POSTGRES_PASSWORD=

# Baked into the web app's browser bundle at Docker build time (see apps/web/Dockerfile).
# Must point at the public URL the API will actually be reachable at once Nginx + the
# subdomain are live, e.g. https://governance.digaf.et/api
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
